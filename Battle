<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="theme-color" content="#FAF9F7" />
<title>왕사슴벌레 4:4 배틀</title>
<style>
:root{--bg:#FAF9F7;--surf:#FFFFFF;--surf2:#F4F2EE;--line:#E7E3DC;--line2:#EFEDE8;
--text:#1C1A17;--dim:#8A8378;--gold:#A8884F;--gold-d:#937640;--green:#6B8E4E;--red:#B4503F;color-scheme:light}
*{box-sizing:border-box;margin:0;-webkit-tap-highlight-color:transparent}
html,body{background:var(--bg)}
.app{min-height:100vh;color:var(--text);max-width:520px;margin:0 auto;padding:18px 16px 60px;
font-family:-apple-system,"Apple SD Gothic Neo","Pretendard","Malgun Gothic",sans-serif;font-size:15px;line-height:1.55}
.mono{font-family:ui-monospace,"SF Mono",Menlo,monospace;letter-spacing:-.01em}
.serif{font-family:"Times New Roman","Nanum Myeongjo",Georgia,serif}
.boot{padding:80px 20px;text-align:center;color:var(--dim)}
.head{text-align:center;padding:6px 0 18px;border-bottom:1px solid var(--line);margin-bottom:16px}
.head-eyebrow{font-size:11px;letter-spacing:.34em;color:var(--gold-d);font-weight:700}
.head-title{font-family:"Times New Roman","Nanum Myeongjo",Georgia,serif;font-size:27px;font-weight:700;margin-top:8px}
.head-sub{font-size:12.5px;color:var(--dim);margin-top:5px}
.mode{display:inline-block;margin-top:12px;font-size:11.5px;font-weight:700;color:var(--gold-d);
border:1px solid #A8884F55;border-radius:999px;padding:3px 12px;background:#FCFAF5}
.score{background:var(--surf);border:1px solid #D8D2C8;border-radius:16px;padding:22px 12px 18px;
box-shadow:0 2px 12px rgba(28,26,23,.06);display:flex;align-items:stretch;margin-bottom:10px}
.side{flex:1;text-align:center;min-width:0}
.side-name{font-size:13px;font-weight:800;display:flex;align-items:center;justify-content:center;gap:6px}
.side-name i{width:8px;height:8px;border-radius:50%;flex:none}
.side-score{font-family:"Times New Roman","Nanum Myeongjo",Georgia,serif;font-size:44px;font-weight:700;
margin-top:6px;line-height:1;font-variant-numeric:tabular-nums}
.side-score small{font-size:15px;color:var(--dim);font-weight:400;margin-left:2px}
.side-sub{font-size:11px;color:var(--dim);margin-top:7px}
.side.lead .side-score{color:var(--gold-d)}
.crown{font-size:13px}
.vs{flex:none;display:flex;align-items:center;padding:0 6px;color:#BCB5A9;
font-family:"Times New Roman",Georgia,serif;font-style:italic;font-size:17px}
.gap-note{text-align:center;font-size:12px;color:var(--dim);margin-bottom:18px}
.gap-note b{color:var(--gold-d)}
.p-t{font-size:12px;font-weight:800;color:var(--dim);letter-spacing:.06em;text-transform:uppercase;margin:22px 2px 11px}
.panel{background:var(--surf);border:1px solid var(--line);border-radius:13px;padding:14px 15px;margin-bottom:10px}
.rrow{display:flex;align-items:center;gap:11px;padding:10px 0;border-top:1px solid var(--line2)}
.rrow:first-child{border-top:none;padding-top:2px}
.rrow:last-child{padding-bottom:2px}
.rk{flex:none;width:24px;text-align:center;font-weight:800;font-size:14px;color:var(--dim);font-variant-numeric:tabular-nums}
.rk.g{color:var(--gold-d)}
.rname{flex:1;min-width:0}
.rname b{font-size:14.5px;display:flex;align-items:center;gap:6px}
.rname b i{width:7px;height:7px;border-radius:50%;flex:none}
.rname span{font-size:11.5px;color:var(--dim);display:block;margin-top:2px}
.rval{flex:none;text-align:right;font-size:18px;font-weight:700;font-variant-numeric:tabular-nums}
.rval small{font-size:12px;color:var(--dim);font-weight:400}
.bar-row{display:flex;align-items:center;gap:9px;padding:5px 0}
.bar-name{flex:none;width:64px;font-size:12px;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.bar-track{flex:1;background:var(--surf2);border-radius:5px;height:16px;overflow:hidden}
.bar-fill{height:100%;border-radius:5px;min-width:2px}
.bar-val{flex:none;width:48px;text-align:right;font-size:12px;font-weight:700;font-variant-numeric:tabular-nums}
.legend{display:flex;gap:14px;justify-content:center;font-size:11.5px;color:var(--dim);margin-top:9px;flex-wrap:wrap}
.legend i{display:inline-block;width:8px;height:8px;border-radius:50%;margin-right:4px}
details{background:var(--surf);border:1px solid var(--line);border-radius:13px;margin-bottom:9px;overflow:hidden}
summary{list-style:none;cursor:pointer;padding:13px 15px;display:flex;align-items:center;gap:9px}
summary::-webkit-details-marker{display:none}
.sm-dot{width:8px;height:8px;border-radius:50%;flex:none}
.sm-name{font-weight:700;font-size:14.5px}
.sm-sub{font-size:11.5px;color:var(--dim);margin-left:auto}
.sm-arrow{color:var(--dim);font-size:12px;flex:none}
.tbl-wrap{overflow-x:auto;border-top:1px solid var(--line2);padding:6px 15px 13px}
table{border-collapse:collapse;width:100%;font-size:12.5px;font-variant-numeric:tabular-nums}
th{color:var(--dim);font-size:11px;font-weight:700;text-align:right;padding:7px 4px 5px;border-bottom:1px solid var(--line2);white-space:nowrap}
th:first-child,td:first-child{text-align:left}
td{text-align:right;padding:6px 4px;border-bottom:1px solid var(--line2);white-space:nowrap}
tr:last-child td{border-bottom:none}
.sx-m{color:#5A7A9A;font-weight:700}.sx-f{color:#A8884F;font-weight:700}
.empty-d{font-size:13px;color:var(--dim);text-align:center;padding:14px 0;line-height:1.7}
.foot{margin-top:30px;text-align:center;font-size:11.5px;color:#BCB5A9;line-height:1.8}
.foot a{color:var(--gold-d);text-decoration:none;font-weight:700}
svg{display:block}
</style>
</head>
<body>
<div id="root" class="app"><div class="boot">불러오는 중…</div></div>

<script>
/* ══ Supabase 연결 정보 — anon key만 붙여넣으세요 (app.js에 있는 것과 동일) ══ */
var SUPA_URL = "https://qybgsztoegkzqsdipili.supabase.co";
var SUPA_ANON = "여기에_ANON_KEY_붙여넣기";

function render(B) {
  B = B || {};
  var rounds = B.rounds || [];
  var teams = B.teams || {};
  var teamKeys = Object.keys(teams);

  /* ── 유틸 ── */
  function esc(s) { return String(s == null ? "" : s).replace(/[&<>"']/g, function (c) { return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]; }); }
  function num(v) { var n = parseFloat(v); return isFinite(n) && n > 0 ? n : null; }
  function n1(v) { return v == null ? "—" : (Math.round(v * 10) / 10).toLocaleString(); }
  function avg(a) { var x = a.filter(function (v) { return v != null; }); return x.length ? x.reduce(function (s, v) { return s + v; }, 0) / x.length : null; }
  function tcolor(k) { return (teams[k] && teams[k].color) || "#8A8378"; }
  function tname(k) { return (teams[k] && teams[k].name) || ("팀 " + k); }

  /* ── 데이터 정리 ── */
  var breeders = (B.breeders || []).map(function (br) {
    return {
      name: br.name || "?", team: br.team || "?",
      larvae: (br.larvae || []).map(function (r) {
        return { code: r[0] || "", sex: String(r[1] || ""), weights: Array.isArray(r[2]) ? r[2] : [], adult: num(r[3]) };
      })
    };
  });
  function sexOf(s) { return s.indexOf("수") >= 0 ? "m" : s.indexOf("암") >= 0 ? "f" : "u"; }
  function latestW(l) { for (var i = l.weights.length - 1; i >= 0; i--) { var v = num(l.weights[i]); if (v != null) return v; } return null; }

  var adultCnt = breeders.reduce(function (a, b) { return a + b.larvae.filter(function (l) { return l.adult != null; }).length; }, 0);
  var mode = adultCnt > 0 ? "adult" : "weight";
  var unit = mode === "adult" ? "mm" : "g";
  var metric = function (l) { return mode === "adult" ? l.adult : latestW(l); };
  var modeLabel = mode === "adult" ? "성충 총장 · 암수 평균 (공식 스코어)" : "유충 무게 중간 집계 · 최종 승부는 성충 총장";

  /* ── 브리더별 스코어 (암수 평균) ── */
  function stats(br) {
    var vs = br.larvae.map(function (l) { return { v: metric(l), s: sexOf(l.sex) }; }).filter(function (x) { return x.v != null; });
    var m = avg(vs.filter(function (x) { return x.s === "m"; }).map(function (x) { return x.v; }));
    var f = avg(vs.filter(function (x) { return x.s === "f"; }).map(function (x) { return x.v; }));
    var score = (m != null && f != null) ? (m + f) / 2 : (m != null ? m : f);
    return { m: m, f: f, score: score, cnt: vs.length, total: br.larvae.length };
  }
  var ranked = breeders.map(function (br) { var s = stats(br); return { br: br, s: s }; })
    .sort(function (a, b) { return (b.s.score || -1) - (a.s.score || -1); });

  /* ── 팀 스코어 = 팀원 스코어 평균 ── */
  function teamScore(k) {
    var ss = ranked.filter(function (r) { return r.br.team === k && r.s.score != null; }).map(function (r) { return r.s.score; });
    return { score: avg(ss), n: ss.length };
  }
  var tA = teamKeys[0], tB = teamKeys[1];
  var sA = tA ? teamScore(tA) : { score: null, n: 0 };
  var sB = tB ? teamScore(tB) : { score: null, n: 0 };
  var lead = (sA.score != null && sB.score != null) ? (sA.score > sB.score ? tA : sA.score < sB.score ? tB : null) : (sA.score != null ? tA : sB.score != null ? tB : null);

  var html = "";

  /* ── 헤더 ── */
  html += '<div class="head">'
    + '<div class="head-eyebrow serif">BREEDERS BATTLE</div>'
    + '<div class="head-title">' + esc(B.title || "4 : 4 배틀") + '</div>'
    + '<div class="head-sub">' + esc(B.subtitle || "") + (B.season ? " · " + esc(B.season) : "") + '</div>'
    + '<div class="mode">' + esc(modeLabel) + '</div>'
    + '</div>';

  /* ── VS 스코어보드 ── */
  function sideHTML(k, s) {
    var isLead = lead === k;
    return '<div class="side' + (isLead ? " lead" : "") + '">'
      + '<div class="side-name"><i style="background:' + tcolor(k) + '"></i>' + esc(tname(k)) + (isLead ? ' <span class="crown">👑</span>' : "") + '</div>'
      + '<div class="side-score">' + (s.score != null ? n1(s.score) : "—") + '<small>' + unit + '</small></div>'
      + '<div class="side-sub">브리더 ' + s.n + '명 집계</div>'
      + '</div>';
  }
  if (tA && tB) {
    html += '<div class="score">' + sideHTML(tA, sA) + '<div class="vs">vs</div>' + sideHTML(tB, sB) + '</div>';
    if (sA.score != null && sB.score != null) {
      var gap = Math.abs(sA.score - sB.score);
      html += '<div class="gap-note">' + (gap < 0.05 ? "동점 접전 중!" : '격차 <b class="mono">' + n1(gap) + unit + '</b> — ' + esc(tname(lead)) + ' 리드') + '</div>';
    } else {
      html += '<div class="gap-note">데이터가 모이면 팀 스코어가 표시돼요</div>';
    }
  }

  /* ── 브리더 랭킹 ── */
  html += '<div class="p-t">브리더 랭킹 · 암수 평균</div><div class="panel">';
  if (!ranked.length) html += '<div class="empty-d">참가자 데이터를 기다리는 중…</div>';
  ranked.forEach(function (r, i) {
    var s = r.s;
    var sub = s.cnt
      ? '수 ' + n1(s.m) + unit + ' · 암 ' + n1(s.f) + unit + ' · ' + s.cnt + "/" + s.total + "마리"
      : "데이터 전 · " + s.total + "마리 등록";
    html += '<div class="rrow">'
      + '<div class="rk' + (i === 0 && s.score != null ? " g" : "") + '">' + (s.score != null ? i + 1 : "–") + '</div>'
      + '<div class="rname"><b><i style="background:' + tcolor(r.br.team) + '"></i>' + esc(r.br.name) + '</b><span>' + esc(tname(r.br.team)) + ' · ' + sub + '</span></div>'
      + '<div class="rval mono">' + (s.score != null ? n1(s.score) + '<small>' + unit + '</small>' : '<small>—</small>') + '</div>'
      + '</div>';
  });
  html += '</div>';

  /* ── 개체 TOP 10 ── */
  var allL = [];
  breeders.forEach(function (br) {
    br.larvae.forEach(function (l) { var v = metric(l); if (v != null) allL.push({ br: br, l: l, v: v }); });
  });
  allL.sort(function (a, b) { return b.v - a.v; });
  if (allL.length) {
    html += '<div class="p-t">개체 TOP 10</div><div class="panel">';
    allL.slice(0, 10).forEach(function (x, i) {
      var sx = sexOf(x.l.sex);
      html += '<div class="rrow">'
        + '<div class="rk' + (i === 0 ? " g" : "") + '">' + (i + 1) + '</div>'
        + '<div class="rname"><b><i style="background:' + tcolor(x.br.team) + '"></i>' + esc(x.br.name) + ' <span class="mono" style="font-size:12px;color:var(--dim)">' + esc(x.l.code) + '</span>'
        + (sx === "m" ? ' <span class="sx-m">♂</span>' : sx === "f" ? ' <span class="sx-f">♀</span>' : "") + '</b></div>'
        + '<div class="rval mono">' + n1(x.v) + '<small>' + unit + '</small></div>'
        + '</div>';
    });
    html += '</div>';
  }

  /* ── 브리더 평균 막대 ── */
  var withScore = ranked.filter(function (r) { return r.s.score != null; });
  if (withScore.length) {
    var maxS = Math.max.apply(null, withScore.map(function (r) { return r.s.score; }));
    html += '<div class="p-t">브리더 평균 비교</div><div class="panel">';
    withScore.forEach(function (r) {
      var w = Math.max(4, Math.round((r.s.score / maxS) * 100));
      html += '<div class="bar-row">'
        + '<div class="bar-name">' + esc(r.br.name) + '</div>'
        + '<div class="bar-track"><div class="bar-fill" style="width:' + w + '%;background:' + tcolor(r.br.team) + '"></div></div>'
        + '<div class="bar-val mono">' + n1(r.s.score) + unit + '</div>'
        + '</div>';
    });
    html += '<div class="legend">' + teamKeys.map(function (k) { return '<span><i style="background:' + tcolor(k) + '"></i>' + esc(tname(k)) + '</span>'; }).join("") + '</div></div>';
  }

  /* ── 라운드별 성장 곡선 (라운드 2개부터) ── */
  function roundAvgs(br) {
    return rounds.map(function (_, i) {
      return avg(br.larvae.map(function (l) { return num(l.weights[i]); }));
    });
  }
  if (rounds.length >= 2) {
    var series = breeders.map(function (br) { return { name: br.name, team: br.team, vals: roundAvgs(br) }; })
      .filter(function (s) { return s.vals.some(function (v) { return v != null; }); });
    var flat = [];
    series.forEach(function (s) { s.vals.forEach(function (v) { if (v != null) flat.push(v); }); });
    if (flat.length >= 2) {
      var W = 320, H = 170, P = 26;
      var mn = Math.min.apply(null, flat), mx = Math.max.apply(null, flat);
      if (mx - mn < 0.5) { mx += 0.5; mn -= 0.5; }
      var X = function (i) { return P + i * ((W - 2 * P) / Math.max(1, rounds.length - 1)); };
      var Y = function (v) { return H - P - ((v - mn) * (H - 2 * P)) / (mx - mn); };
      var svg = '<svg viewBox="0 0 ' + W + ' ' + H + '" style="width:100%">';
      svg += '<line x1="' + P + '" y1="' + (H - P) + '" x2="' + (W - P) + '" y2="' + (H - P) + '" stroke="#E7E3DC"/>';
      rounds.forEach(function (r, i) {
        svg += '<text x="' + X(i) + '" y="' + (H - 8) + '" font-size="10" fill="#8A8378" text-anchor="middle">' + esc(r) + '</text>';
      });
      series.forEach(function (s) {
        var pts = [];
        s.vals.forEach(function (v, i) { if (v != null) pts.push([X(i), Y(v)]); });
        if (pts.length >= 2) svg += '<polyline points="' + pts.map(function (p) { return p.join(","); }).join(" ") + '" fill="none" stroke="' + tcolor(s.team) + '" stroke-width="1.6" stroke-linejoin="round" opacity=".8"/>';
        pts.forEach(function (p, i) { svg += '<circle cx="' + p[0] + '" cy="' + p[1] + '" r="' + (i === pts.length - 1 ? 3 : 1.8) + '" fill="' + tcolor(s.team) + '"/>'; });
      });
      svg += '</svg>';
      html += '<div class="p-t">라운드별 평균 무게</div><div class="panel">' + svg
        + '<div class="legend">' + teamKeys.map(function (k) { return '<span><i style="background:' + tcolor(k) + '"></i>' + esc(tname(k)) + '</span>'; }).join("") + '</div></div>';
    }
  }

  /* ── 참가자별 상세 ── */
  html += '<div class="p-t">참가자별 상세</div>';
  ranked.forEach(function (r) {
    var br = r.br, s = r.s;
    html += '<details><summary>'
      + '<i class="sm-dot" style="background:' + tcolor(br.team) + '"></i>'
      + '<span class="sm-name">' + esc(br.name) + '</span>'
      + '<span class="sm-sub mono">' + (s.score != null ? n1(s.score) + unit + " · " : "") + br.larvae.length + '마리</span>'
      + '<span class="sm-arrow">▾</span></summary>';
    if (!br.larvae.length) {
      html += '<div class="empty-d">아직 데이터가 없어요</div>';
    } else {
      html += '<div class="tbl-wrap"><table><tr><th>번호</th><th>성별</th>'
        + rounds.map(function (rd) { return '<th>' + esc(rd) + '</th>'; }).join("")
        + '<th>성충</th></tr>';
      br.larvae.forEach(function (l) {
        var sx = sexOf(l.sex);
        html += '<tr><td class="mono">' + esc(l.code) + '</td>'
          + '<td>' + (sx === "m" ? '<span class="sx-m">♂</span>' : sx === "f" ? '<span class="sx-f">♀</span>' : '<span style="color:var(--dim)">—</span>') + '</td>'
          + rounds.map(function (_, i) { var v = num(l.weights[i]); return '<td class="mono">' + (v != null ? n1(v) : "·") + '</td>'; }).join("")
          + '<td class="mono">' + (l.adult != null ? n1(l.adult) + "mm" : "·") + '</td></tr>';
      });
      html += '</table></div>';
    }
    html += '</details>';
  });

  /* ── 푸터 ── */
  html += '<div class="foot">'
    + (B.updated ? '마지막 업데이트 ' + esc(B.updated) + '<br/>' : "")
    + 'powered by <a href="./">BeetleLog</a> — 사육기록장 · <a href="battle-admin.html" style="color:#BCB5A9;font-weight:400">관리</a></div>';

  document.getElementById("root").innerHTML = html;
}

/* ── 데이터 불러오기 ── */
(function () {
  var root = document.getElementById("root");
  fetch(SUPA_URL + "/rest/v1/battle?id=eq.1&select=data,updated_at", {
    headers: { apikey: SUPA_ANON, Authorization: "Bearer " + SUPA_ANON }
  }).then(function (r) {
    if (!r.ok) throw new Error("HTTP " + r.status);
    return r.json();
  }).then(function (rows) {
    var row = rows && rows[0];
    var B = (row && row.data) || {};
    if (row && row.updated_at && !B.updated) B.updated = String(row.updated_at).slice(0, 10);
    if (!B.breeders || !B.breeders.length) {
      root.innerHTML = '<div class="boot">🪲<br/><br/>아직 배틀 데이터가 없어요.<br/>관리자가 첫 데이터를 입력하면 여기에 표시됩니다.</div>';
      return;
    }
    render(B);
  }).catch(function (e) {
    root.innerHTML = '<div class="boot">⚠️ 데이터를 불러오지 못했어요.<br/>잠시 후 새로고침 해주세요.<br/><span style="font-size:11px">(' + String(e && e.message || e) + ')</span></div>';
  });
})();
</script>
</body>
</html>

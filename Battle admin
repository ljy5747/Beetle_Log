<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="theme-color" content="#FAF9F7" />
<title>배틀 관리</title>
<style>
:root{--bg:#FAF9F7;--surf:#FFFFFF;--surf2:#F4F2EE;--line:#E7E3DC;--line2:#EFEDE8;
--text:#1C1A17;--dim:#8A8378;--gold:#A8884F;--gold-d:#937640;--green:#6B8E4E;--red:#B4503F;color-scheme:light}
*{box-sizing:border-box;margin:0;-webkit-tap-highlight-color:transparent}
html,body{background:var(--bg)}
.app{min-height:100vh;color:var(--text);max-width:520px;margin:0 auto;padding:16px 16px 80px;
font-family:-apple-system,"Apple SD Gothic Neo","Pretendard","Malgun Gothic",sans-serif;font-size:15px;line-height:1.55}
.mono{font-family:ui-monospace,"SF Mono",Menlo,monospace;letter-spacing:-.01em}
.serif{font-family:"Times New Roman","Nanum Myeongjo",Georgia,serif}
.boot{padding:80px 20px;text-align:center;color:var(--dim);line-height:2}
.topbar{display:flex;justify-content:space-between;align-items:center;gap:10px;padding:4px 0 13px;border-bottom:1px solid var(--line);margin-bottom:16px}
.brand{font-family:"Times New Roman","Nanum Myeongjo",Georgia,serif;font-size:21px;font-weight:700}
.brand small{font-size:12px;color:var(--dim);font-weight:400;font-family:-apple-system,sans-serif;display:block;margin-top:1px}
.hbtn{background:none;border:none;color:var(--gold-d);font-size:14px;font-weight:700;padding:8px 2px;cursor:pointer;font-family:inherit}
.login-box{text-align:center;padding:60px 10px}
.login-box .icon{font-size:44px;margin-bottom:14px}
.login-t{font-size:17px;font-weight:800;margin-bottom:8px}
.login-d{font-size:13px;color:var(--dim);line-height:1.8;margin-bottom:22px}
.btn{background:var(--surf);border:1px solid var(--line);color:var(--text);border-radius:11px;
padding:12px 16px;font-size:14.5px;font-weight:700;cursor:pointer;font-family:inherit}
.btn.primary{background:var(--gold);border-color:var(--gold);color:#fff}
.btn.big{width:100%;padding:15px}
.sect{font-size:11px;font-weight:800;color:var(--gold-d);letter-spacing:.08em;text-transform:uppercase;margin:22px 2px 11px}
.sect:first-of-type{margin-top:4px}
.panel{background:var(--surf);border:1px solid var(--line);border-radius:13px;padding:14px 15px;margin-bottom:10px}
.row{display:flex;gap:10px}
.field{margin-bottom:12px;flex:1;min-width:0}
.field:last-child{margin-bottom:2px}
.label{font-size:12px;color:var(--dim);font-weight:700;margin-bottom:6px}
.in{width:100%;background:var(--surf);border:1px solid var(--line);color:var(--text);border-radius:11px;
padding:11px 12px;font-size:16px;font-family:inherit;appearance:none}
.in:focus{outline:none;border-color:var(--gold)}
textarea.in{min-height:110px;resize:vertical;font-family:ui-monospace,"SF Mono",Menlo,monospace;font-size:14px;line-height:1.7;white-space:pre}
select.in{background-image:linear-gradient(45deg,transparent 50%,var(--dim) 50%),linear-gradient(135deg,var(--dim) 50%,transparent 50%);
background-position:calc(100% - 18px) 50%,calc(100% - 13px) 50%;background-size:5px 5px;background-repeat:no-repeat}
.hint{font-size:11.5px;color:var(--dim);margin-top:7px;line-height:1.7}
.hint b{color:var(--text)}
.bblock{background:var(--surf);border:1px solid var(--line);border-radius:13px;padding:13px 15px;margin-bottom:10px}
.bhead{display:flex;gap:8px;margin-bottom:10px}
.bhead .in{padding:9px 11px;font-size:15px}
.bhead .name{flex:1.4}
.bhead .team{flex:1}
.bdel{flex:none;background:none;border:none;color:var(--dim);font-size:17px;cursor:pointer;padding:0 4px}
.pv{font-size:12px;margin-top:8px;line-height:1.7}
.pv .ok{color:var(--green);font-weight:700}
.pv .err{color:var(--red);font-weight:600;display:block}
.addb{width:100%;background:var(--surf2);border:1px dashed var(--line);color:var(--dim);border-radius:13px;
padding:13px;font-size:14px;font-weight:700;cursor:pointer;font-family:inherit;margin-bottom:10px}
.savebar{position:fixed;bottom:0;left:0;right:0;background:linear-gradient(transparent,var(--bg) 30%);padding:20px 16px 22px;z-index:40}
.savebar-in{max-width:520px;margin:0 auto;display:flex;gap:9px}
.savebar-in .btn{flex:1}
.toast{position:fixed;bottom:86px;left:50%;transform:translateX(-50%);background:var(--text);
color:#fff;border-radius:999px;padding:10px 18px;font-size:13.5px;font-weight:600;z-index:99;
box-shadow:0 8px 24px rgba(28,26,23,.25);white-space:nowrap;max-width:92vw;overflow:hidden;text-overflow:ellipsis}
.guide{background:#FCFAF5;border:1px solid #A8884F44;border-radius:12px;padding:12px 14px;font-size:12.5px;line-height:1.8;color:#6B5A38;margin-bottom:14px}
.guide b{font-family:ui-monospace,Menlo,monospace}
</style>
</head>
<body>
<div id="root" class="app"><div class="boot">불러오는 중…</div></div>

<script>
/* ══ Supabase 연결 정보 — anon key만 붙여넣으세요 (battle.html과 동일) ══ */
var SUPA_URL = "https://qybgsztoegkzqsdipili.supabase.co";
var SUPA_ANON = "여기에_ANON_KEY_붙여넣기";

var TOKEN_KEY = "battle-admin-token";
var PAGE_URL = location.origin + location.pathname;
var TEAM_COLORS = { A: "#A8884F", B: "#6E8494" };

/* ══════════ 유틸 ══════════ */
function esc(s) { return String(s == null ? "" : s).replace(/[&<>"']/g, function (c) { return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]; }); }
function $(id) { return document.getElementById(id); }
var toastT = null;
function say(msg) {
  var old = document.querySelector(".toast"); if (old) old.remove();
  var t = document.createElement("div"); t.className = "toast"; t.textContent = msg;
  document.body.appendChild(t);
  clearTimeout(toastT); toastT = setTimeout(function () { t.remove(); }, 3200);
}

/* ══════════ 유충 텍스트 ↔ 데이터 변환 ══════════ */
/*PARSE-START*/
function normSex(t) {
  t = String(t || "");
  if (/[수♂mM]/.test(t)) return "수";
  if (/[암♀fF]/.test(t)) return "암";
  return "";
}
function parseLines(text, nRounds) {
  var larvae = [], errors = [];
  String(text || "").split("\n").forEach(function (line, idx) {
    var s = line.trim(); if (!s) return;
    var t = s.split(/\s+/);
    if (t.length < 2) { errors.push((idx + 1) + "행: 「번호 성별 무게…」 순서로 적어주세요"); return; }
    var code = t[0], sex = normSex(t[1]);
    if (!sex && !/^[?\-.미]/.test(t[1])) { errors.push((idx + 1) + "행: 성별은 수 / 암 / ? 로 적어주세요"); return; }
    var weights = [], adult = null;
    for (var i = 2; i < t.length; i++) {
      var tk = t[i];
      if (/mm$/i.test(tk)) {
        var a = parseFloat(tk);
        if (isFinite(a) && a > 0) adult = a;
        else errors.push((idx + 1) + "행: 성충 총장 값을 확인해주세요");
        continue;
      }
      if (tk === "-" || tk === ".") { weights.push(null); continue; }
      var w = parseFloat(tk);
      if (isFinite(w) && w > 0) weights.push(w);
      else errors.push((idx + 1) + "행: 「" + tk + "」는 숫자가 아니에요");
    }
    if (weights.length > nRounds) errors.push((idx + 1) + "행: 무게 " + weights.length + "개 — 라운드(" + nRounds + "개)보다 많아요. 위 설정에서 라운드를 먼저 추가하세요");
    larvae.push([code, sex, weights, adult]);
  });
  return { larvae: larvae, errors: errors };
}
function larvaeToText(larvae) {
  return (larvae || []).map(function (r) {
    var ws = (Array.isArray(r[2]) ? r[2] : []).map(function (w) { return w == null ? "-" : w; });
    var parts = [r[0] || "?", r[1] || "?"].concat(ws);
    if (r[3] != null) parts.push(r[3] + "mm");
    return parts.join(" ");
  }).join("\n");
}
/*PARSE-END*/

/* ══════════ 인증 ══════════ */
function captureHashToken() {
  if (location.hash.indexOf("access_token") < 0) return;
  var p = new URLSearchParams(location.hash.slice(1));
  var tok = {
    access_token: p.get("access_token"),
    refresh_token: p.get("refresh_token"),
    expires_at: Date.now() + (parseInt(p.get("expires_in") || "3600", 10) - 120) * 1000,
  };
  try { localStorage.setItem(TOKEN_KEY, JSON.stringify(tok)); } catch (e) {}
  history.replaceState(null, "", PAGE_URL);
}
function getToken() {
  try {
    var t = JSON.parse(localStorage.getItem(TOKEN_KEY));
    if (t && t.access_token && t.expires_at > Date.now()) return t;
  } catch (e) {}
  return null;
}
function login() {
  location.href = SUPA_URL + "/auth/v1/authorize?provider=google&redirect_to=" + encodeURIComponent(PAGE_URL);
}
function logout() {
  try { localStorage.removeItem(TOKEN_KEY); } catch (e) {}
  location.reload();
}

/* ══════════ 상태 ══════════ */
var S = null; /* {title, subtitle, season, rounds[], teams{}, breeders[{name,team,text}]} */
var userEmail = "";

function defaultState() {
  var bs = [];
  for (var i = 1; i <= 8; i++) bs.push({ name: "참가자" + i, team: i <= 4 ? "A" : "B", text: "" });
  return {
    title: "왕사슴벌레 4 : 4 배틀",
    subtitle: "성충 총장 · 브리더별 암수 평균 승부",
    season: "2026 시즌",
    rounds: ["1병"],
    teams: { A: { name: "팀 A", color: TEAM_COLORS.A }, B: { name: "팀 B", color: TEAM_COLORS.B } },
    breeders: bs,
  };
}
function stateFromData(B) {
  if (!B || !B.breeders || !B.breeders.length) return defaultState();
  return {
    title: B.title || "왕사슴벌레 4 : 4 배틀",
    subtitle: B.subtitle || "",
    season: B.season || "",
    rounds: (B.rounds && B.rounds.length ? B.rounds : ["1병"]).slice(),
    teams: B.teams || defaultState().teams,
    breeders: B.breeders.map(function (br) {
      return { name: br.name || "", team: br.team === "B" ? "B" : "A", text: larvaeToText(br.larvae) };
    }),
  };
}

/* ══════════ 화면 ══════════ */
function showLogin(extra) {
  $("root").innerHTML =
    '<div class="login-box">'
    + '<div class="icon">🪲</div>'
    + '<div class="login-t serif" style="font-size:21px">Battle Admin</div>'
    + '<div class="login-d">배틀 데이터 입력은 관리자만 가능해요.<br/>구글 계정으로 로그인해주세요.'
    + (extra ? '<br/><span style="color:var(--red)">' + esc(extra) + '</span>' : "") + '</div>'
    + '<button class="btn primary big" id="loginBtn">구글로 로그인</button>'
    + '<div class="hint" style="margin-top:16px">로그인해도 저장은 등록된 관리자 계정만 가능합니다</div>'
    + '</div>';
  $("loginBtn").addEventListener("click", login);
}

function renderForm() {
  var html = '<div class="topbar">'
    + '<div class="brand">Battle <span style="font-style:italic">admin</span><small>' + esc(userEmail || "로그인됨") + '</small></div>'
    + '<button class="hbtn" id="logoutBtn">로그아웃</button></div>';

  html += '<div class="guide">✍️ 유충은 <b>한 줄에 한 마리</b>씩:<br/>'
    + '<b>번호 성별 무게1 무게2 …</b> — 예) <b>01 수 9.4 14.2</b><br/>'
    + '빠진 라운드는 <b>-</b> , 우화하면 맨 뒤에 <b>82.5mm</b> 처럼 추가</div>';

  html += '<div class="sect">기본 설정</div><div class="panel">'
    + '<div class="field"><div class="label">배틀 이름</div><input class="in" id="f-title" value="' + esc(S.title) + '"/></div>'
    + '<div class="row">'
    + '<div class="field"><div class="label">부제</div><input class="in" id="f-subtitle" value="' + esc(S.subtitle) + '"/></div>'
    + '<div class="field"><div class="label">시즌</div><input class="in" id="f-season" value="' + esc(S.season) + '"/></div></div>'
    + '<div class="field"><div class="label">측정 라운드 (쉼표로 구분)</div>'
    + '<input class="in mono" id="f-rounds" value="' + esc(S.rounds.join(", ")) + '"/>'
    + '<div class="hint">병갈이 하면 여기에 추가 — 예: <b>1병, 2병</b></div></div>'
    + '<div class="row">'
    + '<div class="field"><div class="label">팀 A 이름</div><input class="in" id="f-ta" value="' + esc(S.teams.A ? S.teams.A.name : "팀 A") + '"/></div>'
    + '<div class="field"><div class="label">팀 B 이름</div><input class="in" id="f-tb" value="' + esc(S.teams.B ? S.teams.B.name : "팀 B") + '"/></div></div>'
    + '</div>';

  html += '<div class="sect">참가자 ' + S.breeders.length + '명</div>';
  S.breeders.forEach(function (br, i) {
    html += '<div class="bblock">'
      + '<div class="bhead">'
      + '<input class="in name" id="b-name-' + i + '" value="' + esc(br.name) + '" placeholder="이름"/>'
      + '<select class="in team" id="b-team-' + i + '">'
      + '<option value="A"' + (br.team !== "B" ? " selected" : "") + '>팀 A</option>'
      + '<option value="B"' + (br.team === "B" ? " selected" : "") + '>팀 B</option></select>'
      + '<button class="bdel" id="b-del-' + i + '" title="삭제">✕</button></div>'
      + '<textarea class="in" id="b-text-' + i + '" placeholder="01 수 9.4&#10;02 암 5.8">' + esc(br.text) + '</textarea>'
      + '<div class="pv" id="b-pv-' + i + '"></div>'
      + '</div>';
  });
  html += '<button class="addb" id="addBreeder">＋ 참가자 추가</button>';

  html += '<div style="height:52px"></div>'
    + '<div class="savebar"><div class="savebar-in">'
    + '<button class="btn" id="previewBtn">배틀 페이지 보기</button>'
    + '<button class="btn primary" id="saveBtn">저장하기</button>'
    + '</div></div>';

  $("root").innerHTML = html;

  $("logoutBtn").addEventListener("click", logout);
  $("addBreeder").addEventListener("click", function () { readForm(); S.breeders.push({ name: "", team: "A", text: "" }); renderForm(); });
  $("previewBtn").addEventListener("click", function () { window.open("battle.html", "_blank"); });
  $("saveBtn").addEventListener("click", save);
  S.breeders.forEach(function (_, i) {
    $("b-text-" + i).addEventListener("input", function () { updatePreview(i); });
    $("b-del-" + i).addEventListener("click", function () {
      if (!confirmDel(i)) return;
      readForm(); S.breeders.splice(i, 1); renderForm();
    });
    updatePreview(i);
  });
}

var delArm = { i: -1, t: 0 };
function confirmDel(i) {
  if (delArm.i === i && Date.now() - delArm.t < 2600) { delArm.i = -1; return true; }
  delArm = { i: i, t: Date.now() };
  say("한 번 더 누르면 이 참가자를 삭제해요");
  return false;
}

function currentRounds() {
  return String($("f-rounds").value || "").split(/[,，]+/).map(function (s) { return s.trim(); }).filter(Boolean);
}
function updatePreview(i) {
  var r = parseLines($("b-text-" + i).value, currentRounds().length);
  var cnt = { 수: 0, 암: 0, "": 0 };
  r.larvae.forEach(function (l) { cnt[l[1]] = (cnt[l[1]] || 0) + 1; });
  var elm = $("b-pv-" + i);
  var head = r.larvae.length
    ? '<span class="ok">✓ ' + r.larvae.length + "마리</span> · 수 " + cnt["수"] + " / 암 " + cnt["암"] + (cnt[""] ? " / 미구분 " + cnt[""] : "")
    : '<span style="color:var(--dim)">데이터 없음</span>';
  elm.innerHTML = head + r.errors.map(function (e) { return '<span class="err">⚠️ ' + esc(e) + "</span>"; }).join("");
}

function readForm() {
  S.title = $("f-title").value.trim();
  S.subtitle = $("f-subtitle").value.trim();
  S.season = $("f-season").value.trim();
  S.rounds = currentRounds();
  S.teams = {
    A: { name: $("f-ta").value.trim() || "팀 A", color: TEAM_COLORS.A },
    B: { name: $("f-tb").value.trim() || "팀 B", color: TEAM_COLORS.B },
  };
  S.breeders = S.breeders.map(function (_, i) {
    return { name: $("b-name-" + i).value.trim(), team: $("b-team-" + i).value, text: $("b-text-" + i).value };
  });
}

/* ══════════ 저장 ══════════ */
function save() {
  readForm();
  if (!S.rounds.length) return say("⚠️ 라운드를 1개 이상 입력해주세요 (예: 1병)");
  var breeders = [], errCount = 0;
  S.breeders.forEach(function (br, i) {
    var r = parseLines(br.text, S.rounds.length);
    if (r.errors.length) errCount += r.errors.length;
    breeders.push({ name: br.name || "참가자" + (i + 1), team: br.team, larvae: r.larvae });
  });
  if (errCount) return say("⚠️ 입력 오류 " + errCount + "건 — 빨간 표시를 고쳐주세요");

  var D = {
    title: S.title, subtitle: S.subtitle, season: S.season,
    updated: new Date().toISOString().slice(0, 10),
    rounds: S.rounds, teams: S.teams, breeders: breeders,
  };
  var tok = getToken();
  if (!tok) { showLogin("로그인이 만료됐어요 — 다시 로그인해주세요"); return; }

  $("saveBtn").textContent = "저장 중…";
  fetch(SUPA_URL + "/rest/v1/battle", {
    method: "POST",
    headers: {
      apikey: SUPA_ANON,
      Authorization: "Bearer " + tok.access_token,
      "Content-Type": "application/json",
      Prefer: "resolution=merge-duplicates",
    },
    body: JSON.stringify({ id: 1, data: D, updated_at: new Date().toISOString() }),
  }).then(function (r) {
    $("saveBtn").textContent = "저장하기";
    if (r.ok) { say("✓ 저장 완료 — 배틀 페이지에 바로 반영돼요"); return; }
    if (r.status === 401) { showLogin("로그인이 만료됐어요 — 다시 로그인해주세요"); return; }
    if (r.status === 403 || r.status === 42501) { say("⚠️ 저장 권한이 없어요 — SQL의 관리자 이메일을 확인해주세요"); return; }
    return r.text().then(function (t) {
      if (t && t.indexOf("42501") >= 0) say("⚠️ 저장 권한이 없어요 — SQL의 관리자 이메일과 로그인 계정이 같은지 확인");
      else say("⚠️ 저장 실패 (" + r.status + ")");
    });
  }).catch(function () {
    $("saveBtn").textContent = "저장하기";
    say("⚠️ 네트워크 오류 — 다시 시도해주세요");
  });
}

/* ══════════ 시작 ══════════ */
(function boot() {
  captureHashToken();
  var tok = getToken();
  if (!tok) { showLogin(); return; }

  /* 로그인 이메일 확인 + 기존 데이터 로드 */
  Promise.all([
    fetch(SUPA_URL + "/auth/v1/user", { headers: { apikey: SUPA_ANON, Authorization: "Bearer " + tok.access_token } })
      .then(function (r) { return r.ok ? r.json() : null; }).catch(function () { return null; }),
    fetch(SUPA_URL + "/rest/v1/battle?id=eq.1&select=data", { headers: { apikey: SUPA_ANON, Authorization: "Bearer " + SUPA_ANON } })
      .then(function (r) { return r.ok ? r.json() : []; }).catch(function () { return []; }),
  ]).then(function (res) {
    var user = res[0], rows = res[1];
    if (!user || !user.email) { try { localStorage.removeItem(TOKEN_KEY); } catch (e) {} showLogin("세션이 만료됐어요 — 다시 로그인해주세요"); return; }
    userEmail = user.email;
    S = stateFromData(rows && rows[0] && rows[0].data);
    renderForm();
  });
})();
</script>
</body>
</html>
